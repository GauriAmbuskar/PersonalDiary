<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Diary</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body class="bg-zinc-900">

    <div class="min-h-screen">

        <!-- Header -->
        <div class="flex justify-between items-center px-10 py-6">

            <div>
                <h1 class="text-4xl font-bold text-white">
                    Welcome, <%= user.name %> 👋
                </h1>

                <p class="text-zinc-400 mt-1">
                    Keep your memories safe.
                </p>
            </div>

            <a
                href="/logout"
                class="bg-red-500 hover:bg-red-600 transition px-5 py-2 rounded-lg text-white">
                Logout
            </a>

        </div>

        <!-- Create Diary -->

        <div class="px-10">

            <form
                action="/create"
                method="POST"
                class="bg-zinc-800 rounded-xl p-6">

                <input
                    type="text"
                    name="title"
                    placeholder="Diary Title"
                    required
                    class="w-full px-4 py-3 rounded-lg bg-zinc-700 text-white outline-none mb-4">

                <textarea
                    name="details"
                    rows="6"
                    placeholder="Write your thoughts..."
                    required
                    class="w-full px-4 py-3 rounded-lg bg-zinc-700 text-white outline-none resize-none"></textarea>

                <button
                    class="mt-5 bg-blue-600 hover:bg-blue-700 transition px-6 py-2 rounded-lg text-white">

                    Create Diary

                </button>

            </form>

        </div>

        <!-- Diary List -->

        <div class="px-10 py-10">

            <h2 class="text-3xl text-white mb-6">
                My Diary Entries
            </h2>

            <% if(user.posts.length === 0){ %>

                <div class="text-zinc-500 text-lg">
                    No diary entries yet.
                </div>

            <% } else { %>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

                    <% user.posts.forEach(post => { %>

                        <div class="bg-zinc-800 rounded-xl p-5">

                            <h2 class="text-white text-2xl font-semibold">
                                <%= post.title %>
                            </h2>

                            <p class="text-zinc-400 mt-3 line-clamp-3">
                                <%= post.details.substring(0,120) %>...
                            </p>

                            <div class="flex justify-between items-center mt-6">

                                <a
                                    href="/post/<%= post._id %>"
                                    class="text-blue-400 hover:text-blue-300">
                                    Read More
                                </a>

                                <div class="flex gap-4">

                                    <a
                                        href="/edit/<%= post._id %>"
                                        class="text-green-400 hover:text-green-300">
                                        Edit
                                    </a>

                                    <form
                                        action="/delete/<%= post._id %>"
                                        method="POST">

                                        <button
                                            class="text-red-400 hover:text-red-300">
                                            Delete
                                        </button>

                                    </form>

                                </div>

                            </div>

                        </div>

                    <% }) %>

                </div>

            <% } %>

        </div>

    </div>

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Diary</title>

    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-zinc-900">

    <div class="min-h-screen p-10">

        <a
            href="/profile"
            class="text-blue-500">
            ← Back to Profile
        </a>

        <h1 class="text-4xl text-white mt-8 mb-8">
            Edit Diary
        </h1>

        <form
            action="/edit/<%= post._id %>"
            method="POST">

            <input
                type="text"
                name="title"
                value="<%= post.title %>"
                class="w-full bg-zinc-800 text-white rounded-lg px-4 py-3 outline-none mb-5"
                required>

            <textarea
                name="details"
                rows="10"
                class="w-full bg-zinc-800 text-white rounded-lg px-4 py-3 outline-none resize-none"
                required><%= post.details %></textarea>

            <button
                class="mt-5 bg-yellow-500 hover:bg-yellow-600 text-white px-6 py-2 rounded-lg">

                Update Diary

            </button>

        </form>

    </div>

</body>
</html>
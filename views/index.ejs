<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTS-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Document</title>
        <link rel="stylesheet" href="/stylesheets/style.css">
        <script src="https://cdn.tailwindcss.com"></script>
    </head>
    <body>
        <div class="main w-full min-h-screen bg-zinc-900 text-white p-10">
            <h3 class="text-3xl mb-5 ">Create Account</h3>
                <form action="/register" method="post">
                    <input class="px-3 py-2 bg-transparent rounded-md border-2 border-zinc-800 outline-none type="text" placeholder="Username" name="username">
                    <input class="px-3 py-2 bg-transparent rounded-md border-2 border-zinc-800 outline-none" type="text"  placeholder="Name" name="name">
                    <input class="px-3 py-2 bg-transparent rounded-md border-2 border-zinc-800 outline-none" type="number" placeholder="Age" name="age">
                    <input class="px-3 py-2 bg-transparent rounded-md border-2 border-zinc-800 outline-none" type="text" placeholder="Email" name="email">
                    <input class="px-3 py-2 bg-transparent rounded-md border-2 border-zinc-800 outline-none" type="password" placeholder="Password" name="password">
                    <input class="mt-2 bg-blue-600 px-5 py-2 rounded-md" type="submit" value="Create Account">
                </form>
                <br>
                 <div class="flex items-center mt-5">
                    <h5 class="text-blue-300">Already have an account?</h5>
                    <a href="/login" class="ml-5 bg-blue-600 px-4 py-1 rounded-md">
                    Login
                    </a>
                </div>
        </div>

        <script src="/javascripts/script.js"></script>
    </body>
</html>